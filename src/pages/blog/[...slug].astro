---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import FormattedDate from '../../components/FormattedDate.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout title={post.data.title} description={post.data.description}>
  <a
    href="/blog"
    class="text-sm text-zinc-500 transition-colors hover:text-[var(--color-accent)] dark:text-zinc-400"
  >
    ← Back to writing
  </a>

  <article class="prose prose-zinc mt-6 max-w-none dark:prose-invert prose-a:text-[var(--color-accent)] prose-headings:tracking-tight prose-headings:[font-family:var(--font-heading)]">
    <header class="not-prose mb-8">
      <h1 class="font-display text-3xl font-semibold tracking-tight sm:text-4xl">{post.data.title}</h1>
      <p class="mt-3 text-sm text-zinc-500 dark:text-zinc-400">
        <FormattedDate date={post.data.pubDate} />
        {post.data.updatedDate && (
          <span> · updated <FormattedDate date={post.data.updatedDate} /></span>
        )}
      </p>
    </header>

    <Content />
  </article>
</BaseLayout>
