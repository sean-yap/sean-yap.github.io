---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import FormattedDate from '../../components/FormattedDate.astro';

export async function getStaticPaths() {
  // Drafts render in `npm run dev` for review but are excluded from the
  // deployed build.
  const projects = (await getCollection('projects')).filter(
    (project) => !project.data.draft || import.meta.env.DEV
  );
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content, headings } = await render(project);
const toc = headings.filter((heading) => heading.depth === 2);
---

<BaseLayout title={project.data.title} description={project.data.description}>
  <a
    href="/#work"
    class="text-sm text-zinc-500 transition-colors hover:text-[var(--color-accent)] dark:text-zinc-400"
  >
    ← Back to work
  </a>

  {project.data.draft && (
    <p class="mt-6 rounded-lg border border-dashed border-[var(--color-accent)] px-4 py-3 text-sm text-[var(--color-accent)]">
      <strong>Draft.</strong> Visible in local dev only; not part of the deployed site until <code>draft: false</code>.
    </p>
  )}

  <article class="prose prose-zinc mt-6 max-w-none dark:prose-invert prose-a:text-[var(--color-accent)] prose-headings:tracking-tight prose-headings:[font-family:var(--font-heading)]">
    <header class="not-prose mb-10">
      <h1 class="font-display text-3xl font-semibold tracking-tight sm:text-4xl">
        {project.data.title}
      </h1>

      <p class="mt-4 text-lg leading-relaxed text-zinc-600 dark:text-zinc-400">
        {project.data.problem}
      </p>

      <p class="accent-soft mt-4 inline-flex items-center gap-2 rounded-md px-2.5 py-1 text-sm font-medium text-[var(--color-accent)]">
        <span class="text-xs font-semibold uppercase tracking-wide opacity-70">Impact</span>
        <span>{project.data.impact}</span>
      </p>

      <div class="mt-5 flex flex-wrap items-center gap-x-4 gap-y-2 text-sm text-zinc-500 dark:text-zinc-400">
        <FormattedDate date={project.data.pubDate} />
        {project.data.updatedDate && (
          <span>· updated <FormattedDate date={project.data.updatedDate} /></span>
        )}
        {project.data.stack.length > 0 && (
          <span class="flex flex-wrap gap-2">
            {project.data.stack.map((item) => (
              <span class="rounded-md bg-zinc-100 px-2 py-0.5 text-xs text-zinc-600 dark:bg-zinc-800 dark:text-zinc-400">
                {item}
              </span>
            ))}
          </span>
        )}
      </div>
    </header>

    {toc.length > 1 && (
      <nav class="not-prose mb-10 rounded-lg border border-zinc-200 px-5 py-4 dark:border-zinc-800">
        <p class="text-xs font-semibold uppercase tracking-wide text-zinc-500 dark:text-zinc-400">
          On this page
        </p>
        <ol class="mt-3 space-y-1.5 text-sm">
          {toc.map((heading) => (
            <li>
              <a
                href={`#${heading.slug}`}
                class="text-zinc-600 transition-colors hover:text-[var(--color-accent)] dark:text-zinc-300"
              >
                {heading.text}
              </a>
            </li>
          ))}
        </ol>
      </nav>
    )}

    <Content />
  </article>
</BaseLayout>
