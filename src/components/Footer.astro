---
import { SITE, SOCIALS } from '../config';
const year = new Date().getFullYear();

const links = [
  SOCIALS.github && { label: 'GitHub', href: SOCIALS.github },
  SOCIALS.linkedin && { label: 'LinkedIn', href: SOCIALS.linkedin },
  SOCIALS.email && { label: 'Email', href: `mailto:${SOCIALS.email}` },
].filter(Boolean) as { label: string; href: string }[];
---

<footer class="mt-16 w-full max-w-2xl border-t border-zinc-200 py-8 text-sm text-zinc-500 dark:border-zinc-800 dark:text-zinc-400">
  <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
    <p>© {year} {SITE.name}</p>
    <div class="flex gap-4">
      {
        links.map((link) => (
          <a
            href={link.href}
            class="transition-colors hover:text-[var(--color-accent)]"
            target={link.href.startsWith('http') ? '_blank' : undefined}
            rel={link.href.startsWith('http') ? 'noopener noreferrer' : undefined}
          >
            {link.label}
          </a>
        ))
      }
    </div>
  </div>
</footer>
