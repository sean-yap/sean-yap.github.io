---
import { SITE, SOCIALS, NAV_LINKS, ROLE } from '../config';
import ThemeToggle from './ThemeToggle.astro';

const path = Astro.url.pathname;
const isActive = (href: string) => {
  if (href.startsWith('/#')) return path === '/';
  return path === href || path.startsWith(href + '/');
};

const socials = [
  SOCIALS.github && { label: 'GitHub', href: SOCIALS.github },
  SOCIALS.linkedin && { label: 'LinkedIn', href: SOCIALS.linkedin },
  SOCIALS.email && { label: 'Email', href: `mailto:${SOCIALS.email}` },
].filter(Boolean) as { label: string; href: string }[];
---

<header
  class="sticky top-0 z-40 bg-white/80 backdrop-blur-md md:flex md:h-screen md:w-48 md:shrink-0 md:flex-col md:bg-transparent md:py-16 md:backdrop-blur-none lg:w-56 dark:bg-zinc-950/80 md:dark:bg-transparent"
>
  <!-- Top row: name + (mobile) controls -->
  <div
    class="flex items-center justify-between border-b border-zinc-200 py-4 md:block md:border-0 md:py-0 dark:border-zinc-800"
  >
    <a
      href="/"
      class="font-display text-lg font-semibold tracking-tight hover:text-[var(--color-accent)]"
    >
      {SITE.name}
    </a>
    <p class="mt-2 hidden text-sm text-zinc-500 md:block dark:text-zinc-400">
      {ROLE}
    </p>

    <div class="flex items-center gap-2 md:hidden">
      <ThemeToggle />
      <button
        id="menu-button"
        type="button"
        aria-label="Open menu"
        aria-expanded="false"
        class="inline-flex h-9 w-9 items-center justify-center rounded-lg border border-zinc-200 text-zinc-600 dark:border-zinc-800 dark:text-zinc-400"
      >
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5M3.75 17.25h16.5" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Desktop nav -->
  <nav class="mt-8 hidden md:flex md:flex-col md:gap-0.5">
    {
      NAV_LINKS.map((link) => (
        <a
          href={link.href}
          class:list={[
            'rounded-md px-2 py-1 text-sm transition-colors hover:bg-zinc-100 dark:hover:bg-zinc-800',
            isActive(link.href)
              ? 'font-medium text-[var(--color-accent)]'
              : 'text-zinc-600 dark:text-zinc-400',
          ]}
        >
          {link.label}
        </a>
      ))
    }
  </nav>

  <!-- Desktop socials + theme toggle (pinned to bottom) -->
  <div class="mt-auto hidden md:block">
    <div class="flex flex-col gap-1 text-sm text-zinc-500 dark:text-zinc-400">
      {
        socials.map((s) => (
          <a
            href={s.href}
            target={s.href.startsWith('http') ? '_blank' : undefined}
            rel={s.href.startsWith('http') ? 'noopener noreferrer' : undefined}
            class="px-2 py-0.5 transition-colors hover:text-[var(--color-accent)]"
          >
            {s.label}
          </a>
        ))
      }
    </div>
    <div class="mt-4 px-2">
      <ThemeToggle />
    </div>
  </div>

  <!-- Mobile dropdown -->
  <nav
    id="mobile-menu"
    class="hidden flex-col gap-0.5 border-b border-zinc-200 pb-3 md:hidden dark:border-zinc-800"
  >
    {
      NAV_LINKS.map((link) => (
        <a
          href={link.href}
          class:list={[
            'rounded-md px-2 py-2 text-sm transition-colors hover:bg-zinc-100 dark:hover:bg-zinc-800',
            isActive(link.href)
              ? 'font-medium text-[var(--color-accent)]'
              : 'text-zinc-600 dark:text-zinc-400',
          ]}
        >
          {link.label}
        </a>
      ))
    }
  </nav>
</header>

<script is:inline>
  const btn = document.getElementById('menu-button');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    const open = menu?.classList.toggle('hidden') === false;
    menu?.classList.toggle('flex', open);
    btn.setAttribute('aria-expanded', String(open));
  });
</script>
